(defwindow floating-media []
    :monitor 0
    :geometry (geometry :anchor "top center"
                        :width "400px")
    :exclusive false
    :stacking "fg"
    :focusable false
    :namespace "eww-media"
  (box :class "floating-media"
       :orientation "vertical"
       :space-evenly false
    (big-media :show-album-bg true
               :album-image-size 124
               :show-album-image true)
  )
)
