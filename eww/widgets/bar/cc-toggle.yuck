
(defwidget cc-toggle []
  (eventbox :onclick "sh scripts/eww-window.sh toggle control-center" 
            :onrightclick "makoctl mode -t dnd"
            :class "control-center-toggle ${ window_state_control-center == "open" ? "open" : "closed" }"
    (box :class "button"
      { notification_modes =~ "dnd" ? "󰂠" : "󰂚"}
    )
  )
)
