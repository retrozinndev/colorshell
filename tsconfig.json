{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "allowJs": false,
    "module": "esnext",
    "target": "es2025",
    "lib": ["ES2025"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "types": ["./@types"],
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4"
  }
}
