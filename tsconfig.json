{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "allowJs": false,
    "noImplicitThis": true,
    "lib": ["ES2024"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "types": ["./.types/gi"]
  }
}
